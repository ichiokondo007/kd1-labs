# ============================================================
# KD1 環境変数テンプレート
# ============================================================
# このファイルをコピーして環境に合わせた .env を作成する。
#
#   ローカル開発（アプリはホスト実行）: cp .env.example .env.local
#   Docker 全載せ:                     cp .env.example .env.docker
#   チームサーバ:                      cp .env.example .env.server
#
# ※ 値の例はローカル開発用。Docker / サーバ環境では
#    コメント内の補足を参考に書き換えること。
# ============================================================

NODE_ENV=development

# --- MySQL ---
# Docker 内: DB_HOST=mysql / DB_PORT=3306
DB_HOST=localhost
DB_PORT=3306
DB_USER=kd1
DB_PASSWORD=kd1
DB_NAME=kd1

# --- MongoDB ---
# Docker 内: MONGO_HOST=mongodb
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USER=kd1
MONGO_PASSWORD=kd1
MONGO_DATABASE=kd1

# --- MinIO ---
# Docker 内: MINIO_ENDPOINT=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=kd1admin
MINIO_SECRET_KEY=kd1admin1234
MINIO_BUCKET=public

# --- ローカルポート（ホスト公開用 / 競合時に変更可） ---
MYSQL_PORT=3307
MONGO_HOST_PORT=27017
MINIO_CONSOLE_PORT=9001

# --- Server ---
PORT=3000
SESSION_SECRET=kd1-dev-secret

# --- Client（Vite） ---
# VITE_ プレフィックスの変数はブラウザに公開される。
# 未設定時はデフォルト値（localhost）が使われる。
# チームサーバ: サーバの IP またはドメイン名に変更する。
# VITE_API_BASE_URL=
# VITE_GRAFANA_URL=http://localhost:3001
